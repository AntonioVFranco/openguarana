{
  "name": "@openguarana/mcp",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "bin": {
    "openguarana-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev":       "tsx src/index.ts",
    "build":     "tsup src/index.ts --format esm",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk":     "^1.0.0",
    "@openguarana/memory":           "workspace:*",
    "@openguarana/professional":     "workspace:*",
    "@openguarana/security":         "workspace:*",
    "zod":                           "^3.22.0"
  },
  "devDependencies": {
    "@types/node":         "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsup":                "^8.0.0",
    "tsx":                 "^4.0.0",
    "typescript":          "^5.4.0",
    "vitest":              "^2.0.0"
  }
}
