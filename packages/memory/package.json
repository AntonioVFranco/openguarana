{
  "name": "@openguarana/memory",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":     "tsup src/index.ts --format esm && tsc --emitDeclarationOnly --outDir dist",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "sqlite-vec":     "^0.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3":  "^7.6.0",
    "@types/node":            "^22.0.0",
    "@vitest/coverage-v8":    "^2.0.0",
    "tsup":                   "^8.0.0",
    "tsx":                    "^4.0.0",
    "typescript":             "^5.4.0",
    "vitest":                 "^2.0.0"
  }
}
